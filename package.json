{
  "name": "myserver",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/auth-http",
    "apps/admin-api",
    "apps/admin-web",
    "apps/announce-service",
    "apps/mail-service",
    "apps/metrics-collector",
    "tools/mock-client"
  ],
  "scripts": {
    "update:ports": "node apps/update-ports.js",
    "build:all": "powershell -ExecutionPolicy Bypass -File scripts/build-all.ps1",
    "dev:auth": "npm run dev --workspace auth-http",
    "start:auth": "npm run start --workspace auth-http",
    "dev:admin-api": "npm run dev --workspace admin-api",
    "start:admin-api": "npm run start --workspace admin-api",
    "dev:admin-web": "npm run dev --workspace admin-web",
    "build:admin-web": "npm run build --workspace admin-web",
    "dev:announce": "npm run dev --workspace announce-service",
    "start:announce": "npm run start --workspace announce-service",
    "dev:mail": "npm run dev --workspace mail-service",
    "start:mail": "npm run start --workspace mail-service",
    "dev:metrics-collector": "npm run dev --workspace metrics-collector",
    "start:metrics-collector": "npm run start --workspace metrics-collector",
    "dev:mock-client": "npm run dev --workspace mock-client",
    "flow:mock-client": "npm run flow --workspace mock-client --",
    "rollout:transfer": "npm run rollout-transfer --workspace mock-client --",
    "rollout:fault-drill": "npm run rollout-fault-drill --workspace mock-client --",
    "check:mock-client-protocol": "node tools/check-mock-client-protocol.js",
    "generate:proto": "node tools/proto-generate.js --write",
    "check:generated-proto": "node tools/proto-generate.js --check",
    "check:proto-breaking": "node tools/check-proto-breaking-changes.js --check",
    "check:proto-routing": "node tools/check-protocol-routing-consistency.js",
    "check:proto-fixtures": "node tools/check-proto-compatibility-fixtures.js",
    "check:client-protocol-version": "node tools/client-protocol-version-policy.js",
    "check:asset-write-boundaries": "node tools/check-asset-write-boundaries.js",
    "check:registry-schema": "node tools/check-registry-schema.js",
    "check:registry-canary-lifecycle": "node tools/check-registry-canary-lifecycle.js",
    "check:registry-outage-drill": "node tools/check-registry-outage-drill.js",
    "check:registry-heartbeat-loss": "node tools/check-registry-heartbeat-loss.js",
    "check:registry-stale-keys": "node tools/check-registry-stale-keys.js",
    "check:registry-schema-mixed-rollout": "node tools/check-registry-schema-mixed-rollout.js",
    "check:registry-fallback-observability": "node tools/check-registry-fallback-observability.js",
    "check:discovery-config": "node tools/check-discovery-config.js",
    "check:deployment-discovery": "node tools/check-deployment-discovery-dry-run.js",
    "check:proto": "npm run check:mock-client-protocol",
    "fmt:rust": "powershell -ExecutionPolicy Bypass -File scripts/rustfmt-non-generated.ps1",
    "global-id:decode": "node tools/global-id-decode.js",
    "test": "node tools/run-node-tests.js tests/**/*.test.mjs",
    "test:auth-http": "node tools/run-node-tests.js tests/auth/auth-http.test.mjs",
    "test:integration": "node tools/run-node-tests.js tests/integration/integration-flow.test.mjs",
    "smoke:security": "node tools/smoke-security-and-ticket.js",
    "test:security": "npm run smoke:security --",
    "count:lines": "node tools/checkfile/count-lines.js"
  },
  "dependencies": {
    "node-kcp-x": "^1.2.3"
  }
}
