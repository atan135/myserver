{
  "name": "myserver",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/auth-http",
    "apps/admin-api",
    "apps/admin-web",
    "apps/announce-service",
    "apps/mail-service",
    "tools/mock-client"
  ],
  "scripts": {
    "update:ports": "node apps/update-ports.js",
    "build:all": "powershell -ExecutionPolicy Bypass -File scripts/build-all.ps1",
    "dev:auth": "npm run dev --workspace auth-http",
    "start:auth": "npm run start --workspace auth-http",
    "dev:admin-api": "npm run dev --workspace admin-api",
    "start:admin-api": "npm run start --workspace admin-api",
    "dev:admin-web": "npm run dev --workspace admin-web",
    "build:admin-web": "npm run build --workspace admin-web",
    "dev:announce": "npm run dev --workspace announce-service",
    "start:announce": "npm run start --workspace announce-service",
    "dev:mail": "npm run dev --workspace mail-service",
    "start:mail": "npm run start --workspace mail-service",
    "dev:mock-client": "npm run dev --workspace mock-client",
    "flow:mock-client": "npm run flow --workspace mock-client --",
    "test": "node --test --experimental-test-isolation=none --test-concurrency=1 tests/*.test.mjs",
    "test:auth-http": "node --test --experimental-test-isolation=none --test-concurrency=1 tests/auth-http.test.mjs",
    "test:integration": "node --test --experimental-test-isolation=none --test-concurrency=1 tests/integration-flow.test.mjs",
    "test:security": "node tools/test-security-and-ticket.js",
    "count:lines": "node tools/checkfile/count-lines.js"
  },
  "dependencies": {
    "node-kcp-x": "^1.2.3"
  }
}
