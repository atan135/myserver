# Announce Service Configuration
HOST=127.0.0.1
ANNOUNCE_PORT=9004
LOG_LEVEL=info
LOG_ENABLE_CONSOLE=true
LOG_ENABLE_FILE=true
LOG_DIR=logs/announce-service

# PostgreSQL
DB_ENABLED=true
DATABASE_URL=postgres://postgres:password@127.0.0.1:5432/myserver_announce
DB_POOL_SIZE=10

# Redis
REDIS_URL=redis://127.0.0.1:6379
REDIS_KEY_PREFIX=

# NATS
NATS_URL=nats://127.0.0.1:4222

# Global ID
GLOBAL_ID_ORIGIN_ID=0
GLOBAL_ID_WORKER_ID=3

# Admin write APIs
ANNOUNCE_ADMIN_TOKEN=dev-only-change-this-announce-admin-token

# Read APIs
ANNOUNCE_READ_AUTH_REQUIRED=true
ANNOUNCE_READ_TOKEN=dev-only-change-this-announce-read-token
TICKET_SECRET=dev-only-change-this-ticket-secret

# Service Registry
SERVICE_NAME=announce-service
SERVICE_INSTANCE_ID=announce-001
SERVICE_BUILD_VERSION=dev
