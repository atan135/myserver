# Announce Service Configuration
HOST=127.0.0.1
ANNOUNCE_PORT=9004
LOG_LEVEL=info
LOG_ENABLE_CONSOLE=true
LOG_ENABLE_FILE=true
LOG_DIR=logs/announce-service

# MySQL
MYSQL_ENABLED=true
MYSQL_URL=mysql://root:password@127.0.0.1:3306/myserver_announce
MYSQL_POOL_SIZE=10

# Redis
REDIS_URL=redis://127.0.0.1:6379

# Service Registry
SERVICE_NAME=announce-service
SERVICE_INSTANCE_ID=announce-001
