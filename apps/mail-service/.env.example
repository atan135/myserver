# Mail Service Configuration
HOST=127.0.0.1
SERVICE_BIND_HOST=127.0.0.1
SERVICE_PUBLIC_HOST=127.0.0.1
MAIL_PORT=9003
NODE_ENV=development
LOG_LEVEL=info
LOG_ENABLE_CONSOLE=true
LOG_ENABLE_FILE=true
LOG_DIR=logs/mail-service

# PostgreSQL
DB_ENABLED=true
DATABASE_URL=postgres://postgres:password@127.0.0.1:5432/myserver_mail
DB_POOL_SIZE=10

# Redis
REDIS_URL=redis://127.0.0.1:6379
REDIS_KEY_PREFIX=
REGISTRY_ENABLED=true
REGISTRY_URL=redis://127.0.0.1:6379
# Reserved unified registry key prefix. Current registry clients still use their built-in key schema.
REGISTRY_KEY_PREFIX=
DISCOVERY_REQUIRED=true

# NATS
NATS_URL=nats://127.0.0.1:4222

# Mail notification outbox (Core NATS publish is best-effort online notification only)
# Poll 100..60000 ms; batch 1..1000; lease 1000..300000 ms; attempts 1..100.
MAIL_OUTBOX_POLL_INTERVAL_MS=5000
MAIL_OUTBOX_BATCH_SIZE=20
MAIL_OUTBOX_LEASE_MS=30000
MAIL_OUTBOX_MAX_ATTEMPTS=8
# Base 100..60000 ms; max 1000..3600000 ms and >= base; jitter ratio 0..1.
MAIL_OUTBOX_BACKOFF_BASE_MS=1000
MAIL_OUTBOX_BACKOFF_MAX_MS=60000
MAIL_OUTBOX_BACKOFF_JITTER_RATIO=0.2
# Retention 1..3650 days; cleanup interval 10000..86400000 ms; batch 1..10000.
MAIL_OUTBOX_SENT_RETENTION_DAYS=7
MAIL_OUTBOX_TERMINAL_RETENTION_DAYS=30
MAIL_OUTBOX_CLEANUP_INTERVAL_MS=3600000
MAIL_OUTBOX_CLEANUP_BATCH_SIZE=500

# Attachment claim attempt lease. Expired attempts can be taken over with the same
# persisted request id; unknown results remain reconciliation_pending instead.
MAIL_CLAIM_LEASE_MS=30000

# Automatic claim reconciliation. Keep enabled in strict environments so expired
# processing and unknown results cannot remain stuck. Recovery queries every healthy
# game-server admin endpoint and retries only the original frozen request.
MAIL_CLAIM_RECOVERY_ENABLED=true
# Poll 100..60000 ms; batch 1..100; lease 5000..300000 ms.
MAIL_CLAIM_RECOVERY_POLL_INTERVAL_MS=5000
MAIL_CLAIM_RECOVERY_BATCH_SIZE=20
MAIL_CLAIM_RECOVERY_LEASE_MS=60000
# Backoff base 100..60000 ms; max 1000..3600000 ms and >= base; attempts 1..100.
MAIL_CLAIM_RECOVERY_BACKOFF_BASE_MS=1000
MAIL_CLAIM_RECOVERY_BACKOFF_MAX_MS=300000
MAIL_CLAIM_RECOVERY_MAX_ATTEMPTS=12
# Graceful shutdown waits 100..60000 ms for the active recovery batch.
MAIL_CLAIM_RECOVERY_SHUTDOWN_TIMEOUT_MS=10000

# Global ID
GLOBAL_ID_ORIGIN_ID=0
GLOBAL_ID_WORKER_ID=2

# Player and internal mail auth
TICKET_SECRET=dev-only-change-this-ticket-secret
MAIL_PLAYER_AUTH_REQUIRED=true
MAIL_SERVICE_TOKEN=dev-only-change-this-mail-service-token

# Game Server Admin
# REGISTRY_ENABLED=true 时从 Redis service registry 发现 game-server.admin。
# Local debug fallback (legacy direct consumer)
# Local fallback only: uncomment these HOST/PORT examples only when registry discovery
# is disabled (REGISTRY_ENABLED=false), discovery is not strict (DISCOVERY_REQUIRED=false),
# and NODE_ENV=development or APP_ENV=local.
# Rejected in strict/test/production discovery; staging should use registry too.
# GAME_SERVER_ADMIN_HOST=127.0.0.1
# GAME_SERVER_ADMIN_PORT=7500
GAME_ADMIN_TOKEN=dev-only-change-this-game-admin-token
GAME_ADMIN_CONNECT_TIMEOUT_MS=3000
GAME_ADMIN_WRITE_TIMEOUT_MS=3000
GAME_ADMIN_READ_TIMEOUT_MS=3000
GAME_ADMIN_MAX_RESPONSE_BYTES=1048576
# Optional service actor sent to game-server admin audit; defaults to SERVICE_INSTANCE_ID/SERVICE_NAME.
GAME_ADMIN_ACTOR=mail-service

# Service Registry
SERVICE_NAME=mail-service
SERVICE_INSTANCE_ID=mail-001
SERVICE_ZONE=local
SERVICE_BUILD_VERSION=dev
