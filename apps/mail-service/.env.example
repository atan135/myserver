# Mail Service Configuration
HOST=127.0.0.1
MAIL_PORT=9003
LOG_LEVEL=info
LOG_ENABLE_CONSOLE=true
LOG_ENABLE_FILE=true
LOG_DIR=logs/mail-service

# PostgreSQL
DB_ENABLED=true
DATABASE_URL=postgres://postgres:password@127.0.0.1:5432/myserver_mail
DB_POOL_SIZE=10

# Redis
REDIS_URL=redis://127.0.0.1:6379
REDIS_KEY_PREFIX=

# NATS
NATS_URL=nats://127.0.0.1:4222

# Global ID
GLOBAL_ID_ORIGIN_ID=0
GLOBAL_ID_WORKER_ID=2

# Player and internal mail auth
TICKET_SECRET=dev-only-change-this-ticket-secret
MAIL_PLAYER_AUTH_REQUIRED=true
MAIL_SERVICE_TOKEN=dev-only-change-this-mail-service-token

# Game Server Admin
GAME_SERVER_ADMIN_HOST=127.0.0.1
GAME_SERVER_ADMIN_PORT=7500
GAME_ADMIN_TOKEN=dev-only-change-this-game-admin-token
GAME_ADMIN_CONNECT_TIMEOUT_MS=3000
GAME_ADMIN_WRITE_TIMEOUT_MS=3000
GAME_ADMIN_READ_TIMEOUT_MS=3000
GAME_ADMIN_MAX_RESPONSE_BYTES=1048576
# Optional service actor sent to game-server admin audit; defaults to SERVICE_INSTANCE_ID/SERVICE_NAME.
GAME_ADMIN_ACTOR=mail-service

# Service Registry
SERVICE_NAME=mail-service
SERVICE_INSTANCE_ID=mail-001
