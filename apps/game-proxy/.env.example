APP_ENV=development
PROXY_HOST=127.0.0.1
SERVICE_BIND_HOST=127.0.0.1
SERVICE_PUBLIC_HOST=127.0.0.1
PROXY_PORT=4000
PROXY_ADMIN_HOST=127.0.0.1
SERVICE_ADMIN_BIND_HOST=127.0.0.1
SERVICE_ADMIN_ADVERTISED_HOST=127.0.0.1
PROXY_ADMIN_PORT=7101
PROXY_ADMIN_TOKEN=dev-only-change-this-proxy-admin-token
# Optional read-only admin token; GET only, POST writes still require PROXY_ADMIN_TOKEN.
# PROXY_ADMIN_READ_TOKEN=dev-only-change-this-proxy-admin-read-token
# Admin write audit. POST requests should include X-Admin-Actor for operator identity.
PROXY_ADMIN_AUDIT_ENABLED=true
PROXY_ADMIN_AUDIT_PATH=logs/game-proxy/admin-audit.jsonl
PROXY_ADMIN_AUDIT_REQUIRE_ACTOR=false
LOG_LEVEL=info
LOG_ENABLE_CONSOLE=true
LOG_ENABLE_FILE=true
LOG_DIR=logs/game-proxy
PROXY_LOCAL_SOCKET_NAME=myserver-game-proxy.sock
REDIS_URL=redis://127.0.0.1:6379
REDIS_KEY_PREFIX=
PROXY_ROUTE_STORE_BACKEND=memory
PROXY_ROUTE_STORE_REDIS_URL=redis://127.0.0.1:6379
PROXY_ROUTE_STORE_KEY_PREFIX=
# Optional old game-server real drain status check for POST /rollout/complete-if-drained.
# When enabled, proxy calls auth-http internal API and only completes rollout if
# ok=true and ownedRoomCount/migratingRoomCount/connectionCount are all 0.
PROXY_ROLLOUT_DRAIN_STATUS_CHECK_ENABLED=false
PROXY_ROLLOUT_DRAIN_STATUS_URL=http://127.0.0.1:3000/api/v1/internal/game-server/rollout-drain-status
PROXY_ROLLOUT_DRAIN_STATUS_TOKEN=
PROXY_ROLLOUT_DRAIN_STATUS_CONNECT_TIMEOUT_MS=3000
PROXY_ROLLOUT_DRAIN_STATUS_READ_TIMEOUT_MS=3000
PROXY_ROLLOUT_DRAIN_STATUS_OVERALL_TIMEOUT_MS=3000
PROXY_ROLLOUT_DRAIN_STATUS_MAX_BODY_BYTES=1048576
NATS_URL=nats://127.0.0.1:4222
TICKET_SECRET=dev-only-change-this-ticket-secret
PROXY_MAX_CONNECTIONS=0
PROXY_MAX_PREAUTH_FAILURES=3
PROXY_MSG_RATE_WINDOW_MS=1000
PROXY_MSG_RATE_MAX=0
PROXY_MAINTENANCE_CACHE_TTL_MS=2000
PROXY_REDIS_BLOCKLIST_ENABLED=false
PROXY_REDIS_BLOCKLIST_CACHE_TTL_MS=2000
PROXY_IP_DENYLIST=
PROXY_MAX_CONNECTIONS_PER_IP=0
PROXY_MAX_CONNECTIONS_PER_PLAYER=0
SERVICE_TCP_FALLBACK_ADVERTISED_HOST=127.0.0.1
REGISTRY_ENABLED=true
REGISTRY_URL=redis://127.0.0.1:6379
REGISTRY_KEY_PREFIX=
DISCOVERY_REQUIRED=true
REGISTRY_DISCOVER_INTERVAL_SECS=5
UPSTREAM_SERVICE_NAME=game-server
SERVICE_NAME=game-proxy
SERVICE_INSTANCE_ID=game-proxy-4000
SERVICE_BUILD_VERSION=dev
SERVICE_ZONE=local
# Local fallback only: used only when registry discovery is disabled and discovery is not strict.
# Ignored in strict/test/production discovery; use service registry for game-server endpoints there.
UPSTREAM_SERVER_ID=game-server-1
UPSTREAM_LOCAL_SOCKET_NAME=myserver-game-server.sock
