GAME_HOST=127.0.0.1
SERVICE_BIND_HOST=127.0.0.1
SERVICE_PUBLIC_HOST=127.0.0.1
GAME_PORT=7000
APP_ENV=development
CSV_DIR=csv
CSV_RELOAD_ENABLED=true
CSV_RELOAD_INTERVAL_SECS=3
ROOM_CLEANUP_INTERVAL_SECS=10
LOG_LEVEL=info
LOG_ENABLE_CONSOLE=true
LOG_ENABLE_FILE=true
LOG_DIR=logs/game-server
REDIS_URL=redis://127.0.0.1:6379
REDIS_KEY_PREFIX=
GLOBAL_ID_ORIGIN_ID=0
GLOBAL_ID_WORKER_ID=5
NATS_URL=nats://127.0.0.1:4222
DB_ENABLED=false
DATABASE_URL=postgres://postgres:password@127.0.0.1:5432/myserver_game
DB_POOL_SIZE=10
# Development placeholder only; production must replace this with the auth-http ticket secret.
TICKET_SECRET=replace-with-a-long-random-string
HEARTBEAT_TIMEOUT_SECS=30
MAX_BODY_LEN=4096
OUTBOUND_QUEUE_CAPACITY=1024
MSG_RATE_WINDOW_MS=1000
MSG_RATE_MAX=0
PLAYER_MSG_RATE_WINDOW_MS=1000
PLAYER_MSG_RATE_MAX=0
INPUT_TIMESTAMP_REQUIRED=false
INPUT_TIMESTAMP_MAX_SKEW_MS=5000
INPUT_ANOMALY_WINDOW_MS=10000
INPUT_ANOMALY_MAX=0
# Character discipline limits. Invalid or zero values fall back to these defaults.
MAX_LEARNED_DISCIPLINES=8
MAX_ACTIVE_DISCIPLINES=2
GAME_LOCAL_SOCKET_NAME=myserver-game-server.sock
# Game-server self bind name for its published internal local-socket endpoint.
# This is not a legacy consumer fallback; other services should discover it through the registry outside local debug fallback.
GAME_INTERNAL_SOCKET_NAME=myserver-game-server-internal.sock
# Development placeholder only; production must replace this internal service token.
GAME_INTERNAL_TOKEN=dev-only-change-this-game-internal-token

# Admin port for monitoring / admin-api
ADMIN_HOST=127.0.0.1
SERVICE_ADMIN_BIND_HOST=127.0.0.1
SERVICE_ADMIN_ADVERTISED_HOST=127.0.0.1
ADMIN_PORT=7500
# Development placeholder only; production must replace this admin token.
GAME_ADMIN_TOKEN=dev-only-change-this-game-admin-token
# Admin TCP write-operation JSONL audit. Production must keep audit enabled.
GAME_ADMIN_AUDIT_ENABLED=true
GAME_ADMIN_AUDIT_PATH=logs/game-server/admin-audit.jsonl
# When true, admin TCP write operations require AdminAuthReq JSON body:
# {"token":"...","actor":"ops@example.com"}. Read-only status calls remain allowed.
GAME_ADMIN_AUDIT_REQUIRE_ACTOR=false
# Unified asset entry migration switches. Disabling a switch rejects new writes; it never
# re-enables the retired player ItemAdd protocol or a direct snapshot mutation path.
PLAYER_ASSET_TRANSACTIONS_ENABLED=true
MAIL_CLAIM_ASSET_TRANSACTIONS_ENABLED=true
# Explicitly enable only in an audited local/admin environment.
GM_ASSET_CONSTRUCTION_ENABLED=false
GM_EMERGENCY_ASSET_CORRECTION_ENABLED=false

# Service Registry
REGISTRY_ENABLED=true
REGISTRY_URL=redis://127.0.0.1:6379
REGISTRY_KEY_PREFIX=
DISCOVERY_REQUIRED=true
REGISTRY_HEARTBEAT_INTERVAL=10
SERVICE_NAME=game-server
SERVICE_INSTANCE_ID=game-server-001
SERVICE_BUILD_VERSION=dev
SERVICE_ZONE=local
# SERVICE_ROLLOUT_EPOCH takes precedence over ROLLOUT_EPOCH when both are set.
SERVICE_ROLLOUT_EPOCH=default
# ROLLOUT_EPOCH=default

# Match Service (gRPC)
MATCH_SERVICE_REDISCOVERY_INTERVAL_SECS=30
# Local debug fallback (legacy direct consumer)
# Local fallback only: uncomment this direct endpoint example only when registry discovery
# is disabled (REGISTRY_ENABLED=false), discovery is not strict (DISCOVERY_REQUIRED=false),
# and NODE_ENV=development or APP_ENV=local.
# Strict/test/production/staging discovery rejects this variable and must use
# Redis service registry endpoint: match-service.grpc.
# MATCH_SERVICE_ADDR=http://127.0.0.1:9002
