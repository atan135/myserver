GAME_HOST=127.0.0.1
GAME_PORT=7000
CSV_DIR=csv
CSV_RELOAD_ENABLED=true
CSV_RELOAD_INTERVAL_SECS=3
ROOM_CLEANUP_INTERVAL_SECS=10
LOG_LEVEL=info
LOG_ENABLE_CONSOLE=true
LOG_ENABLE_FILE=true
LOG_DIR=logs/game-server
REDIS_URL=redis://127.0.0.1:6379
REDIS_KEY_PREFIX=
NATS_URL=nats://127.0.0.1:4222
MYSQL_ENABLED=false
MYSQL_URL=mysql://root:password@127.0.0.1:3306/myserver_game
MYSQL_POOL_SIZE=10
# Development placeholder only; production must replace this with the auth-http ticket secret.
TICKET_SECRET=replace-with-a-long-random-string
HEARTBEAT_TIMEOUT_SECS=30
MAX_BODY_LEN=4096
OUTBOUND_QUEUE_CAPACITY=1024
MSG_RATE_WINDOW_MS=1000
MSG_RATE_MAX=0
PLAYER_MSG_RATE_WINDOW_MS=1000
PLAYER_MSG_RATE_MAX=0
INPUT_TIMESTAMP_REQUIRED=false
INPUT_TIMESTAMP_MAX_SKEW_MS=5000
INPUT_ANOMALY_WINDOW_MS=10000
INPUT_ANOMALY_MAX=0
GAME_LOCAL_SOCKET_NAME=myserver-game-server.sock
GAME_INTERNAL_SOCKET_NAME=myserver-game-server-internal.sock
# Development placeholder only; production must replace this internal service token.
GAME_INTERNAL_TOKEN=dev-only-change-this-game-internal-token

# Admin port for monitoring / admin-api
ADMIN_HOST=127.0.0.1
ADMIN_PORT=7500
# Development placeholder only; production must replace this admin token.
GAME_ADMIN_TOKEN=dev-only-change-this-game-admin-token
# Admin TCP write-operation JSONL audit. Production must keep audit enabled.
GAME_ADMIN_AUDIT_ENABLED=true
GAME_ADMIN_AUDIT_PATH=logs/game-server/admin-audit.jsonl
# When true, admin TCP write operations require AdminAuthReq JSON body:
# {"token":"...","actor":"ops@example.com"}. Read-only status calls remain allowed.
GAME_ADMIN_AUDIT_REQUIRE_ACTOR=false

# Service Registry
REGISTRY_ENABLED=false
REGISTRY_URL=redis://127.0.0.1:6379
REGISTRY_HEARTBEAT_INTERVAL=10
SERVICE_NAME=game-server
SERVICE_INSTANCE_ID=game-server-001

# Match Service (gRPC) - fallback address used when registry discovery is disabled
MATCH_SERVICE_ADDR=http://127.0.0.1:9002
