# Test strict discovery overlay. Merge with the base .env.example when running integration tests.
NODE_ENV=test
REGISTRY_ENABLED=true
DISCOVERY_REQUIRED=true
DISALLOW_LEGACY_DIRECT_CONFIG=true
REGISTRY_URL=redis://127.0.0.1:6379
REGISTRY_KEY_PREFIX=test:
SERVICE_ZONE=test
SERVICE_BUILD_VERSION=test
