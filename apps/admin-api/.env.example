PORT=3001
HOST=127.0.0.1
SERVICE_BIND_HOST=127.0.0.1
SERVICE_PUBLIC_HOST=127.0.0.1
NODE_ENV=development
LOG_LEVEL=info
LOG_ENABLE_CONSOLE=true
LOG_ENABLE_FILE=true
LOG_DIR=logs/admin-api

REDIS_URL=redis://127.0.0.1:6379
REDIS_KEY_PREFIX=
NATS_URL=nats://127.0.0.1:4222
SERVICE_NAME=admin-api
SERVICE_INSTANCE_ID=admin-api-001
SERVICE_ZONE=local
SERVICE_BUILD_VERSION=dev
REGISTRY_ENABLED=true
REGISTRY_URL=redis://127.0.0.1:6379
# Reserved unified registry key prefix. Current registry clients still use their built-in key schema.
REGISTRY_KEY_PREFIX=
DISCOVERY_REQUIRED=true

# Local debug fallback (legacy direct consumers)
# Local fallback only: uncomment these legacy direct endpoint examples only when
# registry discovery is disabled (REGISTRY_ENABLED=false), discovery is not strict
# (DISCOVERY_REQUIRED=false), and NODE_ENV=development or APP_ENV=local.
# Strict/test/production/staging discovery rejects these variables and must use
# Redis service registry endpoints: game-server.admin and game-proxy.admin.
# GAME_SERVER_ADMIN_HOST=127.0.0.1
# GAME_SERVER_ADMIN_PORT=7500
# GAME_PROXY_ADMIN_HOST=127.0.0.1
# GAME_PROXY_ADMIN_PORT=7101

DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/myserver_auth
# P2 character title/discipline read-only queries use the game database.
# Defaults to DATABASE_URL with database name changed to myserver_game when unset.
GAME_DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/myserver_game
# ADMIN_GAME_DATABASE_URL is accepted as a legacy/ops alias.
DB_POOL_SIZE=10

JWT_SECRET=replace-with-a-long-random-string-for-jwt
JWT_EXPIRES_IN=8h
ADMIN_SESSION_TTL_SECONDS=28800
ADMIN_LOGIN_MAX_FAILURES=5
ADMIN_LOGIN_FAILURE_WINDOW_SECONDS=900
ADMIN_LOGIN_LOCK_SECONDS=900
TRUST_PROXY=false
TRUSTED_PROXIES=
ADMIN_API_REQUIRE_TLS=false
ADMIN_API_REQUIRE_IP_ALLOWLIST=false
ADMIN_API_IP_ALLOWLIST=127.0.0.1,::1

# Game Server Admin
# Default routing uses Redis service registry discovery for the game-server.admin endpoint.
GAME_ADMIN_TOKEN=dev-only-change-this-game-admin-token
GAME_ADMIN_CONNECT_TIMEOUT_MS=3000
GAME_ADMIN_WRITE_TIMEOUT_MS=3000
GAME_ADMIN_READ_TIMEOUT_MS=3000
GAME_ADMIN_MAX_RESPONSE_BYTES=1048576

# Game Proxy Admin HTTP (read-only monitoring)
# Default routing uses Redis service registry discovery for the game-proxy.admin endpoint.
GAME_PROXY_ADMIN_TOKEN=dev-only-change-this-proxy-admin-token
GAME_PROXY_ADMIN_READ_TOKEN=
GAME_PROXY_ADMIN_REQUEST_TIMEOUT_MS=3000
GAME_PROXY_ADMIN_MAX_RESPONSE_BYTES=1048576

# 管理员初始账号（首次启动时创建）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=AdminPass123!
ADMIN_DISPLAY_NAME=Administrator

# Myforge agent control plane. Key files and the agent map are required only when enabled.
MYFORGE_ENABLED=false
# MYFORGE_SERVER_PRIVATE_KEY_PATH=./keys/myforge_server_private.pem
# MYFORGE_SERVER_PUBLIC_KEY_PATH=./keys/myforge_server_public.pem
# MYFORGE_AGENT_PUBLIC_KEYS_JSON={"dev-pc-001":{"projectId":"myforge-local","publicKeyPath":"./keys/myforge_agent_dev_pc_001_public.pem","label":"Development PC"}}
MYFORGE_AUTH_TTL_MS=60000
MYFORGE_COMMAND_TTL_MS=60000
MYFORGE_CLOCK_SKEW_MS=5000
MYFORGE_HEARTBEAT_INTERVAL_MS=15000
MYFORGE_HEARTBEAT_TIMEOUT_MS=45000
MYFORGE_QUEUE_TTL_MS=900000
MYFORGE_COMMAND_TIMEOUT_MS=120000
MYFORGE_CANCEL_TIMEOUT_MS=10000
MYFORGE_MAX_OUTPUT_BYTES=1048576
MYFORGE_WS_MAX_MESSAGE_BYTES=16777216
MYFORGE_WS_WRITE_TIMEOUT_MS=5000
