MATCH_BIND_ADDR=0.0.0.0:9002
MATCH_PUBLIC_HOST=127.0.0.1
MATCH_TIMEOUT_SECS=30
MAX_CONCURRENT_MATCHES=1000
MATCH_CLEANUP_INTERVAL_SECS=1

LOG_LEVEL=info
LOG_ENABLE_CONSOLE=true
LOG_ENABLE_FILE=true
LOG_DIR=logs/match-service

REDIS_URL=redis://127.0.0.1:6379

REGISTRY_ENABLED=false
REGISTRY_URL=redis://127.0.0.1:6379
REGISTRY_HEARTBEAT_INTERVAL=10
SERVICE_NAME=match-service
SERVICE_INSTANCE_ID=match-service-001

GAME_SERVER_SERVICE_NAME=game-server
GAME_SERVER_INTERNAL_SOCKET_NAME=myserver-game-server-internal.sock
