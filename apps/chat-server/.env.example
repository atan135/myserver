CHAT_BIND_ADDR=0.0.0.0:9001
SERVICE_BIND_HOST=0.0.0.0
SERVICE_PUBLIC_HOST=127.0.0.1
APP_ENV=development
HEARTBEAT_TIMEOUT_SECS=30
MAX_BODY_LEN=4096
CHAT_MSG_RATE_WINDOW_MS=1000
CHAT_MSG_RATE_MAX=0
CHAT_MAX_CONNECTIONS_PER_PLAYER=0
CHAT_MAX_CONNECTIONS_PER_IP=0
CHAT_OUTBOUND_QUEUE_CAPACITY=1024

# Development placeholder only. Production must use the same real TICKET_SECRET as auth-http and game-server.
TICKET_SECRET=replace-with-a-long-random-string
REDIS_URL=redis://127.0.0.1:6379
REDIS_KEY_PREFIX=

GLOBAL_ID_ORIGIN_ID=0
GLOBAL_ID_WORKER_ID=4

DB_ENABLED=false
DATABASE_URL=postgres://postgres:password@127.0.0.1:5432/myserver_chat
DB_POOL_SIZE=5

NATS_URL=nats://127.0.0.1:4222
# 邮件在线通知最大 JSON 字节数；在解析前拒绝超限 payload。
CHAT_MAIL_NOTIFY_MAX_PAYLOAD_BYTES=4096
# v1 event_id 只做进程内短期去重，不作为离线 inbox。
CHAT_MAIL_NOTIFY_DEDUP_CAPACITY=10000
CHAT_MAIL_NOTIFY_DEDUP_TTL_SECS=300
# NATS 订阅重建使用有上限的指数退避。
CHAT_MAIL_NOTIFY_RECONNECT_BASE_MS=1000
CHAT_MAIL_NOTIFY_RECONNECT_MAX_MS=30000

REGISTRY_ENABLED=true
REGISTRY_URL=redis://127.0.0.1:6379
REGISTRY_KEY_PREFIX=
DISCOVERY_REQUIRED=true
REGISTRY_HEARTBEAT_INTERVAL=10
SERVICE_NAME=chat-server
SERVICE_INSTANCE_ID=chat-server-001
SERVICE_ZONE=local
SERVICE_BUILD_VERSION=dev
CHAT_PUBLIC_HOST=127.0.0.1
CHAT_ONLINE_ROUTE_TTL_SECS=60

LOG_LEVEL=info
LOG_ENABLE_CONSOLE=true
LOG_ENABLE_FILE=false
LOG_DIR=logs
