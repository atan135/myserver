# Production strict discovery overlay. Merge with real production secrets and deploy-specific endpoints.
APP_ENV=production
REGISTRY_ENABLED=true
DISCOVERY_REQUIRED=true
REGISTRY_URL=redis://redis:6379
REGISTRY_KEY_PREFIX=
SERVICE_ZONE=prod
# Secure steady-state default. During the bounded compatibility rollout, change this
# to true and set CHAT_MAIL_LEGACY_COMPAT_UNTIL_EPOCH_SECONDS to a future timestamp.
CHAT_MAIL_ACCEPT_LEGACY_PAYLOAD=false
