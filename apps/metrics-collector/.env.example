NATS_URL=nats://127.0.0.1:4222
REDIS_URL=redis://127.0.0.1:6379
NODE_ENV=development
METRICS_SUBJECT=myserver.metrics.>
METRICS_TTL_SECONDS=604800
METRICS_HEARTBEAT_TTL_SECONDS=30

# metrics-collector is a NATS/Redis worker and does not participate in discovery.
# It does not expose a connectable endpoint; keep endpoint registration disabled unless that changes.
SERVICE_REGISTRY_REGISTER=false
REGISTRY_ENABLED=false
REGISTRY_URL=redis://127.0.0.1:6379
REGISTRY_KEY_PREFIX=
DISCOVERY_REQUIRED=false
SERVICE_NAME=metrics-collector
SERVICE_INSTANCE_ID=metrics-collector-001
SERVICE_BUILD_VERSION=dev
