PORT=3000
HOST=127.0.0.1
NODE_ENV=development
LOG_LEVEL=info
LOG_ENABLE_CONSOLE=true
LOG_ENABLE_FILE=true
LOG_DIR=logs/auth-http
REDIS_URL=redis://127.0.0.1:6379
REDIS_KEY_PREFIX=
AUTH_REDIS_BLOCKLIST_ENABLED=false
AUTH_REDIS_BLOCKLIST_CACHE_TTL_MS=2000
NATS_URL=nats://127.0.0.1:4222
SERVICE_INSTANCE_ID=auth-http-001
MYSQL_ENABLED=false
MYSQL_URL=mysql://root:password@127.0.0.1:3306/myserver_auth
MYSQL_POOL_SIZE=10
SESSION_TTL_SECONDS=86400
# Dev placeholder only. Production must use a long random non-default value.
TICKET_SECRET=replace-with-a-long-random-string
TICKET_TTL_SECONDS=900  # 短期票据：15分钟
TRUST_PROXY=false
TRUSTED_PROXIES=
GAME_SERVER_ADMIN_HOST=127.0.0.1
GAME_SERVER_ADMIN_PORT=7500
# Dev placeholder only. Production must use the real game-server admin token.
GAME_ADMIN_TOKEN=dev-only-change-this-game-admin-token
GAME_ADMIN_ACTOR=auth-http
GAME_ADMIN_CONNECT_TIMEOUT_MS=3000
GAME_ADMIN_READ_TIMEOUT_MS=3000
GAME_ADMIN_WRITE_TIMEOUT_MS=3000
GAME_ADMIN_MAX_RESPONSE_BYTES=1048576
GAME_PROXY_HOST=127.0.0.1
GAME_PROXY_PORT=4000

# Rate Limiting (IP-based)
RATELIMIT_ENABLED=true
RATELIMIT_WINDOW_MS=60000
RATELIMIT_MAX=60

# Account Lockout
ACCOUNT_LOCK_ENABLED=true
ACCOUNT_LOCK_MAX_ATTEMPTS=5
ACCOUNT_LOCK_WINDOW_SECONDS=900
ACCOUNT_LOCK_TTL_SECONDS=900

# Ticket Validation
TICKET_VALIDATE_ENABLED=true

# Security Audit (MySQL)
SECURITY_AUDIT_ENABLED=true

# Internal API Token (protects /api/v1/internal/* endpoints)
# Dev may leave empty. Production must set a non-empty value; auth-http fails fast otherwise.
INTERNAL_API_TOKEN=
AUTH_STRICT_SECURITY=false
