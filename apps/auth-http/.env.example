PORT=3000
HOST=127.0.0.1
NODE_ENV=development
LOG_LEVEL=info
LOG_ENABLE_CONSOLE=true
LOG_ENABLE_FILE=true
LOG_DIR=logs/auth-http
REDIS_URL=redis://127.0.0.1:6379
REDIS_KEY_PREFIX=
MYSQL_ENABLED=false
MYSQL_URL=mysql://root:password@127.0.0.1:3306/myserver_auth
MYSQL_POOL_SIZE=10
SESSION_TTL_SECONDS=86400
TICKET_SECRET=replace-with-a-long-random-string
TICKET_TTL_SECONDS=300

# Rate Limiting (IP-based)
RATELIMIT_ENABLED=true
RATELIMIT_WINDOW_MS=60000
RATELIMIT_MAX=60

# Account Lockout
ACCOUNT_LOCK_ENABLED=true
ACCOUNT_LOCK_MAX_ATTEMPTS=5
ACCOUNT_LOCK_WINDOW_SECONDS=900
ACCOUNT_LOCK_TTL_SECONDS=900

# Ticket Validation
TICKET_VALIDATE_ENABLED=true

# Security Audit (MySQL)
SECURITY_AUDIT_ENABLED=true
