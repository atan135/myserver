# MyForge control-plane identity. The agent initiates this WebSocket connection.
ADMIN_API_WS_URL=ws://127.0.0.1:3001/api/v1/myforge/ws
MYFORGE_AGENT_ID=dev-pc-001
MYFORGE_PROJECT_ID=myforge-local

# Generate a distinct Ed25519 key pair for the agent. Keep private keys outside Git.
MYFORGE_AGENT_PRIVATE_KEY_PATH=./keys/myforge_agent_private.pem
MYFORGE_AGENT_PUBLIC_KEY_PATH=./keys/myforge_agent_public.pem
MYFORGE_SERVER_PUBLIC_KEY_PATH=./keys/myforge_server_public.pem

# External workspace. It must exist, but rules/ and artifacts/ may be absent.
MYFORGE_ROOT=C:\path\to\myforge

# Run the agent as the same Windows user that completed local Codex login.
# Use the native Codex executable, not the codex/codex-admin PowerShell
# functions, a .ps1 wrapper, or another user's installation. In PowerShell 7:
#   $codexNative = Get-CodexNativeExe
#   if (-not (Test-Path -LiteralPath $codexNative -PathType Leaf)) { throw "Codex native executable not found" }
#   $env:MYFORGE_CODEX_BIN = $codexNative
# codex-admin uses the same --dangerously-bypass-approvals-and-sandbox flag as
# the danger mode below, but codex-admin itself is not an executable path.
MYFORGE_CODEX_BIN=C:\path\to\codex.exe

# Keep dry-run enabled until registration, signing, limits, and paths are verified.
MYFORGE_DRY_RUN=true

# EXTREMELY DANGEROUS: true invokes Codex with
# --dangerously-bypass-approvals-and-sandbox and grants host-level access.
# This is a local process setting and cannot be enabled by an HTTP task.
MYFORGE_CODEX_DANGEROUS_FULL_ACCESS=false

# Optional trusted local auditor. The program path is relative to MYFORGE_ROOT
# and must remain under tools/. rulesFile may still be null; that skips audit.
MYFORGE_AUDIT_ENABLED=false
# MYFORGE_AUDIT_PROGRAM=tools/fangyuan-auditor.exe
MYFORGE_AUDIT_TIMEOUT_MS=30000

# Agent limits are negotiated down against the admin-api limits.
MYFORGE_AUTH_TTL_MS=60000
MYFORGE_COMMAND_TTL_MS=60000
MYFORGE_CLOCK_SKEW_MS=5000
MYFORGE_HEARTBEAT_INTERVAL_MS=15000
MYFORGE_MAX_COMMAND_TIMEOUT_MS=120000
MYFORGE_CANCEL_TIMEOUT_MS=10000
MYFORGE_MAX_OUTPUT_BYTES=1048576
MYFORGE_WS_MAX_MESSAGE_BYTES=16777216
MYFORGE_WS_WRITE_TIMEOUT_MS=5000

LOG_LEVEL=info
LOG_ENABLE_CONSOLE=true
LOG_ENABLE_FILE=true
LOG_DIR=logs/myforge-agent

# Validate configuration, keys, workspace paths, Codex, and auditor without
# connecting to admin-api (run from the MyServer repository root after setting
# the required variables in the current PowerShell process):
#   cargo run --manifest-path apps/myforge-agent/Cargo.toml -- --check
# Start the WebSocket agent after --check succeeds:
#   cargo run --manifest-path apps/myforge-agent/Cargo.toml
# dotenv loads .env from the process working directory; --manifest-path does
# not make Cargo load apps/myforge-agent/.env when the process cwd is the root.
