{
  "schemaVersion": 1,
  "packetRoutes": {
    "canonical": "apps/game-server/src/protocol/message_type.rs",
    "dispatches": [
      {
        "name": "player",
        "path": "apps/game-server/src/server.rs",
        "function": "dispatch_packet",
        "transport": "game-proxy player packets"
      },
      {
        "name": "internal",
        "path": "apps/game-server/src/internal_server.rs",
        "function": "handle_internal_connection",
        "transport": "game-server internal local socket"
      },
      {
        "name": "admin",
        "path": "apps/game-server/src/admin_server.rs",
        "function": "handle_admin_connection",
        "transport": "game-server admin TCP"
      }
    ],
    "preDispatchControls": [
      {
        "messageType": "AdminAuthReq",
        "route": "admin",
        "source": "apps/game-server/src/admin_server.rs",
        "reason": "Consumed by the authenticated admin connection setup before the command dispatch loop."
      },
      {
        "messageType": "InternalAuthReq",
        "route": "internal",
        "source": "apps/game-server/src/internal_server.rs",
        "reason": "Consumed by the internal local-socket authentication gate before the command dispatch loop."
      }
    ],
    "deferredOutboundMessages": [
      {
        "messageType": "DeprecatedItemAddRes",
        "owner": "game-server",
        "reason": "Message id 1408 is permanently retained for the retired ItemAdd response and is intentionally never produced; retired requests receive ErrorRes instead."
      },
      {
        "messageType": "RoomMemberOfflinePush",
        "owner": "game-server",
        "reason": "The packet id and protobuf shape are retained for the room offline lifecycle, but current disconnect handling has no client delivery producer."
      },
      {
        "messageType": "AuthorityMigrationStartPush",
        "owner": "game-server",
        "reason": "The packet shape is reserved for the planned authority-migration lifecycle; no runtime producer is implemented yet."
      },
      {
        "messageType": "AuthorityMigrationCompletePush",
        "owner": "game-server",
        "reason": "The packet shape is reserved for the planned authority-migration lifecycle; no runtime producer is implemented yet."
      }
    ]
  },
  "mockClient": {
    "sourceDirectory": "tools/mock-client/src",
    "nonGameMessageIdFloor": 20000,
    "reason": "Chat packet ids are owned by chat-server and intentionally have no game-server MessageType or game-server route."
  },
