    "dynamicSources": [
      {
        "path": "apps/game-server/src/**/*.rs",
        "reason": "Room and service layers propagate Result error values into protocol responses; these values are data-flow dependent rather than direct literals at the packet boundary."
      },
      {
        "path": "apps/match-service/src/**/*.rs",
        "reason": "MatchError::error_code() derives response values from matcher state and is intentionally checked as a dynamic source."
      }
    ]
  },
  "rpcConsumers": {
    "MatchService": {
      "implementation": {
        "path": "apps/match-service/src/service/match_service.rs",
        "trait": "MatchService"
      }
    },
    "MatchInternal": {
      "implementation": {
        "path": "apps/match-service/src/service/match_service.rs",
        "trait": "MatchInternal"
      },
      "client": {
        "path": "apps/game-server/src/match_client.rs",
        "receiver": "inner"
      }
    }
  }
}
